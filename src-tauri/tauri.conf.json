{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finança",
  "version": "0.1.0",
  "identifier": "br.com.filip.financa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Finança", "width": 1280, "height": 800, "minWidth": 900, "minHeight": 650 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost" }
  },
  "bundle": { "active": true, "targets": ["msi", "nsis"], "icon": [] }
}
